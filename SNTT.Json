        .loader-wrapper { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000; }
        .spinner { width: 40px; height: 40px; border: 4px solid #374151; border-top: 4px solid #58a6ff; border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }




/* কার্ডের RGB বর্ডার এনিমেশন */
.card { 
    background: #161b22; 
    border: 0.3px solid transparent; 
    border-radius: 8px; 
    padding: 5px; 
    text-align: center; 
    cursor: pointer; 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    height: 100px; 
    overflow: hidden;
    
    /* RGB বর্ডার এনিমেশন */
    background-image: linear-gradient(#161b22, #161b22), linear-gradient(90deg, #ff0000, #ff7300, #fffb00, #48ff00, #00ffd5, #002bff, #ff00c8, #ff0000);
    background-origin: border-box;
    background-clip: padding-box, border-box;
    background-size: 200% 100%;
    animation: rgb-border 15s linear infinite;
}

@keyframes rgb-border {
    0% { background-position: 0% 0%; }
