<body>
    <div id="status" class="loader-wrapper"><div class="spinner"></div></div>
    
    <input type="text" id="search" class="search-box" oninput="filterMatches(this.value)">
    
    <div id="cat-container" class="category-bar"></div>
    <div class="container" id="main"></div>

    <script>

        // আপনার দেওয়া সেই আগের ফরম্যাটের ইউআরএলটি এখানে বসান
        const targetUrl = 'INPUT URL';
        const defaultLogo = "https://cdn-icons-png.flaticon.com/512/2305/2305896.png"; 

        let allChannels = [];
        let categories = new Set();
        let currentActiveCategory = "All";

        async function loadChannels() {
            try {
                const response = await fetch(targetUrl);
                const data = await response.text();
                parseM3U(data);
            } catch (error) { document.getElementById('status').innerHTML = "নেটওয়ার্ক এরর!"; }
        }

        function parseM3U(data) {
            const lines = data.split('\n');
            document.getElementById('status').style.display = 'none';
            let masterCookie = "";
            
            for (let i = 0; i < lines.length; i++) {
                let line = lines[i].trim();
                if (line.includes("Edge-Cache-Cookie=")) {
                    masterCookie = line.split("Edge-Cache-Cookie=")[1].split(/[ "']/)[0];
                }
                if (line.startsWith("#EXTINF")) {
                    const name = line.split(',').pop().trim();
                    const group = line.includes('group-title="') ? line.split('group-title="')[1].split('"')[0] : "Others";
                    const logo = line.match(/tvg-logo="(.*?)"/)?.[1] || '';
                    let url = "", channelCookie = "";
                    let j = i + 1;
                    while (j < lines.length && !lines[j].trim().startsWith("#EXTINF")) {
                        let nLine = lines[j].trim();
                        if (nLine.includes("Edge-Cache-Cookie=")) channelCookie = nLine.split("Edge-Cache-Cookie=")[1].split(/[ "']/)[0];
                        if (nLine.startsWith("http")) url = nLine.split('|')[0].trim();
                        j++;
                    }
                    if (url) {
                        allChannels.push({ name, url, logo, group, cookie: channelCookie || masterCookie });
                        categories.add(group);
                    }
                    i = j - 1;
                }
            }
            renderCategories();
            renderChannels(allChannels);
        }

        function renderCategories() {
            const bar = document.getElementById('cat-container');
            bar.innerHTML = `<button class="cat-btn" onclick="filterByCategory('All')">All</button>`;
            Array.from(categories).sort().forEach(cat => bar.innerHTML += `<button class="cat-btn" onclick="filterByCategory('${cat}')">${cat}</button>`);
        }

        function filterByCategory(cat) {
            currentActiveCategory = cat;
            filterMatches('');
        }

        function filterMatches(query) {
            const filtered = allChannels.filter(ch => 
                (currentActiveCategory === 'All' || ch.group === currentActiveCategory) && 
                ch.name.toLowerCase().includes(query.toLowerCase())
            );
            renderChannels(filtered);
        }



        function renderChannels(channels) {
            const main = document.getElementById('main');
            main.innerHTML = '';
            channels.forEach((ch) => {
                const div = document.createElement('div');
                div.className = 'card';
                
                // ইমেজ এলিমেন্ট তৈরি
                const img = document.createElement('img');
                img.src = ch.logo || defaultLogo;
                
                // এরর হ্যান্ডলিং: ইমেজ না পেলে আপনার দেওয়া লোগো দেখাবে
                img.onerror = function() {
                    this.src = 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjkC1LwR663VtQyQXKcpCfB3S-DDsaeuu63if6RkMXcZKNQeKdcyrCWvN65SjzjeMR2yDJnwuCoFavj5ncjkLPc6XKQ2GIK-UTfa8GGmc6SA58eKAHWAnmyDp64dCN8l6Qmrl2YnaorFuSmZqfSO8Hr9v_UQdeSS7QVnDXJTPOiEpMIMqsbD6zIIgUg5Ww/s1254/file_00000000ffb071fa84c1f07f7b4079e7.png';
                };

                div.appendChild(img);
                div.innerHTML += `<div class="name">${ch.name}</div>`;
                
                div.onclick = () => {
                    const finalString = ch.cookie ? `${ch.url}|Cookie=Edge-Cache-Cookie=${ch.cookie}` : ch.url;
                    if (window.AppInventor) window.AppInventor.setWebViewString(finalString);
                    else alert(finalString);
                };
                main.appendChild(div);
            });
        }



        loadChannels();
    </script>
</body>
</html>"
    }
